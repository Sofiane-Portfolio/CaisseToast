<Window x:Class="CaisseToast.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:CaisseToast.Wpf.Views"
        Title="Light Banana — Caisse POS"
        MinWidth="1280" MinHeight="800"
        Width="1440" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <v:ShellHeader Grid.Row="0"
                       DataContext="{Binding Header}"
                       Visibility="{Binding ShowShellHeader, Converter={StaticResource BoolToVis}}"/>

        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentView}"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"/>
    </Grid>
</Window>
