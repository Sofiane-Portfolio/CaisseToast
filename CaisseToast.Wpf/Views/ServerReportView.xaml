<UserControl x:Class="CaisseToast.Wpf.Views.ServerReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource Brush.HeaderGradient}" Padding="24,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Mon rapport" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding ServerName}" FontSize="11" Foreground="#D1EFFE" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="Plan de salle" Style="{StaticResource Btn.HeaderGhost}" HorizontalAlignment="Right" Command="{Binding GoBackCommand}"/>
            </Grid>
        </Border>
        <StackPanel Grid.Row="1" Margin="24" MaxWidth="600" VerticalAlignment="Top">
            <Border Background="White" CornerRadius="16" BorderBrush="#140B128C" BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Shift en cours" FontSize="12" Foreground="{StaticResource Brush.Muted}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ShiftDuration}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <UniformGrid Columns="2">
                <Border Style="{StaticResource KpiCard}" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="{Binding OrdersCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                        <TextBlock Text="Commandes" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Margin="8,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{Binding TablesServed}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                        <TextBlock Text="Tables servies" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Margin="0,8,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding Revenue}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                        <TextBlock Text="Ventes" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Margin="8,8,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding Tips}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                        <TextBlock Text="Pourboires" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>
