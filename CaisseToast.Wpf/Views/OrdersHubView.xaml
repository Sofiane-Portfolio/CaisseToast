<UserControl x:Class="CaisseToast.Wpf.Views.OrdersHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource Brush.HeaderGradient}" Padding="24,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Orders Hub" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Vue centralisée des commandes" FontSize="11" Foreground="#D1EFFE" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="Retour" Style="{StaticResource Btn.HeaderGhost}" HorizontalAlignment="Right" Command="{Binding GoBackCommand}"/>
            </Grid>
        </Border>
        <Border Grid.Row="1" Background="White" Padding="20,12" BorderBrush="#140B128C" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{Binding BannerCount}" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Toutes" Margin="0,0,8,0" Padding="14,8" Command="{Binding SelectChannelCommand}" CommandParameter="all"/>
                    <Button Content="Ouvertes" Margin="0,0,8,0" Padding="14,8" Command="{Binding SelectChannelCommand}" CommandParameter="open"/>
                    <Button Content="Payées" Margin="0,0,8,0" Padding="14,8" Command="{Binding SelectChannelCommand}" CommandParameter="paid"/>
                    <Button Content="En ligne" Padding="14,8" Command="{Binding SelectChannelCommand}" CommandParameter="online"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="2" Padding="24" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Orders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="14" BorderBrush="#140B128C" BorderThickness="1" Padding="16" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Number}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource Brush.Navy}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border Background="#F8FBFF" CornerRadius="6" Padding="6,3" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding TypeLabel}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Brush.Blue}"/>
                                        </Border>
                                        <TextBlock Text="{Binding Meta}" FontSize="11" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalLabel}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    <Button Content="{Binding ActionLabel}" Style="{StaticResource Btn.Primary}" Margin="0,8,0,0" Padding="12,6"
                                            Command="{Binding DataContext.ActOnOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
