<UserControl x:Class="CaisseToast.Wpf.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource Brush.HeaderGradient}" Padding="24,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Payment Terminal" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Open · Paid · Closed" FontSize="11" Foreground="#D1EFFE" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="Retour" Style="{StaticResource Btn.HeaderGhost}" HorizontalAlignment="Right" Command="{Binding GoBackCommand}"/>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="White" CornerRadius="16" BorderBrush="#140B128C" BorderThickness="1" Padding="14" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <UniformGrid Columns="3" Margin="0,0,0,12">
                        <Button Content="{Binding OpenCount, StringFormat=Open ({0})}" Command="{Binding SelectTabCommand}" CommandParameter="open" Margin="2"/>
                        <Button Content="{Binding PaidCount, StringFormat=Paid ({0})}" Command="{Binding SelectTabCommand}" CommandParameter="paid" Margin="2"/>
                        <Button Content="{Binding ClosedCount, StringFormat=Closed ({0})}" Command="{Binding SelectTabCommand}" CommandParameter="closed" Margin="2"/>
                    </UniformGrid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Orders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,8" Padding="12" HorizontalContentAlignment="Stretch" Command="{Binding DataContext.SelectOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#F8FBFF" CornerRadius="12" BorderBrush="#140B128C" BorderThickness="1" Padding="12">
                                                    <StackPanel>
                                                        <Grid>
                                                            <TextBlock Text="{Binding Number}" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                                                            <TextBlock Text="{Binding TotalLabel}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding Meta}" FontSize="10" Foreground="{StaticResource Brush.Muted}"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Border Grid.Column="1" Background="White" CornerRadius="16" BorderBrush="#140B128C" BorderThickness="1" Padding="20">
                <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding DetailTitle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                        <TextBlock Text="{Binding DetailMeta}" Foreground="{StaticResource Brush.Muted}" Margin="0,4,0,8"/>
                        <Border Background="#F8FBFF" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <TextBlock Text="{Binding DetailBanner}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Blue}"/>
                        </Border>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DetailLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <TextBlock Text="{Binding Name}"/>
                                        <TextBlock Text="{Binding TotalLabel}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Margin="0,12">
                        <Grid><TextBlock Text="Subtotal" Foreground="{StaticResource Brush.Muted}"/><TextBlock Text="{Binding DetailSubtotal}" HorizontalAlignment="Right"/></Grid>
                        <Grid Margin="0,4"><TextBlock Text="Tax" Foreground="{StaticResource Brush.Muted}"/><TextBlock Text="{Binding DetailTax}" HorizontalAlignment="Right"/></Grid>
                        <Grid Margin="0,8"><TextBlock Text="Total" FontWeight="Bold"/><TextBlock Text="{Binding DetailTotal}" HorizontalAlignment="Right" FontWeight="Bold"/></Grid>
                    </StackPanel>
                    <UniformGrid Grid.Row="3" Columns="2" Margin="0,12,0,0">
                        <Button Content="Modifier" Margin="4" Command="{Binding UpdateOrderCommand}" Visibility="{Binding CanPay, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Payer" Style="{StaticResource Btn.Primary}" Margin="4" Command="{Binding PayOrderCommand}" Visibility="{Binding CanPay, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Close" Margin="4" Command="{Binding CloseOrderCommand}" Visibility="{Binding CanClose, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Refund" Margin="4" Command="{Binding RefundOrderCommand}" Visibility="{Binding CanRefund, Converter={StaticResource BoolToVis}}"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
