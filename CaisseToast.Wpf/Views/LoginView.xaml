<UserControl x:Class="CaisseToast.Wpf.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Login topbar navy -->
        <Border Grid.Row="0" Background="{StaticResource Brush.HeaderGradient}" Padding="28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="38" CornerRadius="8" Background="#1AFFFFFF" Margin="0,0,14,0">
                        <TextBlock Text="LB" Foreground="White" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="LIGHT BANANA" Foreground="{StaticResource Brush.Sky}"
                                   FontSize="9" FontWeight="Bold"/>
                        <TextBlock Text="Système de caisse" Foreground="White"
                                   FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#1AFFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1"
                        CornerRadius="20" Padding="14,6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource Brush.Live}" Margin="0,0,8,0"/>
                        <TextBlock Text="Système en ligne" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource HeaderPill}">
                        <StackPanel>
                            <TextBlock Text="DATE" Foreground="#73FFFFFF" FontSize="8" FontWeight="Bold"/>
                            <TextBlock Text="{Binding DateText}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource HeaderPill}">
                        <StackPanel>
                            <TextBlock Text="HEURE" Foreground="#73FFFFFF" FontSize="8" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TimeText}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body split -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Brand column -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E2E5EC" BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400">
                    <Border Width="180" Height="180" CornerRadius="90"
                            Background="{StaticResource Brush.PrimaryButton}" Margin="0,0,0,32">
                        <TextBlock Text="R" Foreground="White" FontSize="72" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding RestaurantName}" FontSize="36" FontWeight="Bold"
                               Foreground="{StaticResource Brush.Navy}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Restaurant · Bar · Terrasse" FontSize="15"
                               Foreground="{StaticResource Brush.Sky}" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- PIN column -->
            <Border Grid.Column="1" Background="#F8F9FB" Padding="56,40">
                <StackPanel VerticalAlignment="Center" MaxWidth="420">
                    <TextBlock Text="CODE PIN" Foreground="{StaticResource Brush.Sky}"
                               FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                    <!-- PIN dots -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Ellipse Width="18" Height="18" Margin="8"
                                 Fill="{Binding FilledDots, Converter={StaticResource PinDotFill}, ConverterParameter=0}"/>
                        <Ellipse Width="18" Height="18" Margin="8"
                                 Fill="{Binding FilledDots, Converter={StaticResource PinDotFill}, ConverterParameter=1}"/>
                        <Ellipse Width="18" Height="18" Margin="8"
                                 Fill="{Binding FilledDots, Converter={StaticResource PinDotFill}, ConverterParameter=2}"/>
                        <Ellipse Width="18" Height="18" Margin="8"
                                 Fill="{Binding FilledDots, Converter={StaticResource PinDotFill}, ConverterParameter=3}"/>
                    </StackPanel>

                    <!-- Numpad 3x4 + Go -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="62"/>
                            <RowDefinition Height="62"/>
                            <RowDefinition Height="62"/>
                            <RowDefinition Height="62"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="1"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="2"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="3"/>

                        <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="4"/>
                        <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="7"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="5"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="8"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="6"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="9"/>

                        <Button Grid.Row="3" Grid.Column="0" Content="C" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding ClearCommand}" FontSize="11" FontWeight="Bold"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DigitCommand}" CommandParameter="0"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="Del" Style="{StaticResource Btn.Numpad}" Margin="5"
                                Command="{Binding DeleteCommand}" FontSize="11"/>

                        <Button Grid.Row="0" Grid.Column="3" Grid.RowSpan="4" Content="Go"
                                Style="{StaticResource Btn.Primary}" Margin="5" FontSize="16"
                                Command="{Binding SubmitCommand}"/>
                    </Grid>

                    <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                            CornerRadius="10" Padding="12,8"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Brush.Error}"
                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="PIN démo : 1234 (Manager) · 1111 (Caissier)"
                               Foreground="{StaticResource Brush.Muted}" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
