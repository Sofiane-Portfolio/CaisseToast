<UserControl x:Class="CaisseToast.Wpf.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Background="{StaticResource Brush.HeaderGradient}" Padding="16">
            <StackPanel>
                <TextBlock Text="Admin" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                <Button Content="Dashboard" Style="{StaticResource Btn.HeaderGhost}" Margin="0,4" HorizontalAlignment="Stretch" Command="{Binding SelectTabCommand}" CommandParameter="dashboard"/>
                <Button Content="Produits" Style="{StaticResource Btn.HeaderGhost}" Margin="0,4" HorizontalAlignment="Stretch" Command="{Binding SelectTabCommand}" CommandParameter="products"/>
                <Button Content="Employés" Style="{StaticResource Btn.HeaderGhost}" Margin="0,4" HorizontalAlignment="Stretch" Command="{Binding SelectTabCommand}" CommandParameter="employees"/>
                <Button Content="Paramètres" Style="{StaticResource Btn.HeaderGhost}" Margin="0,4" HorizontalAlignment="Stretch" Command="{Binding SelectTabCommand}" CommandParameter="settings"/>
                <Button Content="Retour" Style="{StaticResource Btn.HeaderGhost}" Margin="0,20,0,0" HorizontalAlignment="Stretch" Command="{Binding GoBackCommand}"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="900">
                <!-- Dashboard -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="dashboard">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Dashboard" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}" Margin="0,0,0,16"/>
                    <UniformGrid Columns="2" Margin="0,0,0,20">
                        <Border Style="{StaticResource KpiCard}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="{Binding OpenOrders}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                                <TextBlock Text="Commandes ouvertes" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource KpiCard}" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding PaidToday}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                                <TextBlock Text="Encaissées aujourd'hui" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource KpiCard}" Margin="0,8,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Revenue}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                                <TextBlock Text="Chiffre d'affaires" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource KpiCard}" Margin="8,8,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding KitchenTickets}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                                <TextBlock Text="Tickets cuisine actifs" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
                <!-- Products -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="products">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Produits" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="12" BorderBrush="#140B128C" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}"/>
                                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{StaticResource Brush.Muted}"/>
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding PriceLabel}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding StockLabel}" FontSize="10" Foreground="{StaticResource Brush.Blue}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <!-- Employees -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="employees">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Employés" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding Employees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="12" BorderBrush="#140B128C" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Role}" HorizontalAlignment="Center" Foreground="{StaticResource Brush.Blue}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Pin}" HorizontalAlignment="Right" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <!-- Settings -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="settings">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Paramètres" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}" Margin="0,0,0,16"/>
                    <Border Background="White" CornerRadius="14" BorderBrush="#140B128C" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Restaurant" FontWeight="Bold" Foreground="{StaticResource Brush.Muted}" FontSize="11"/>
                            <TextBlock Text="{Binding RestaurantName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Brush.Navy}" Margin="0,4,0,16"/>
                            <TextBlock Text="Caisse" FontWeight="Bold" Foreground="{StaticResource Brush.Muted}" FontSize="11"/>
                            <TextBlock Text="{Binding RegisterName}" FontSize="16" Foreground="{StaticResource Brush.Blue}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
