<UserControl x:Class="CaisseToast.Wpf.Views.KitchenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1D2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource Brush.HeaderGradient}" Padding="24,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource Brush.Live}" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Kitchen Display" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Tickets cuisine en temps réel" FontSize="11" Foreground="#D1EFFE"/>
                    </StackPanel>
                </StackPanel>
                <Button Content="Retour" Style="{StaticResource Btn.HeaderGhost}" HorizontalAlignment="Right" Command="{Binding GoBackCommand}"/>
            </Grid>
        </Border>
        <UniformGrid Grid.Row="1" Columns="3" Margin="16">
            <!-- New -->
            <Border Background="#252836" CornerRadius="14" Margin="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding NewCount, StringFormat=Nouveau ({0})}" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding NewTickets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2F3348" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="#4ADE80" FontSize="16"/>
                                            <TextBlock Text="{Binding TabName}" Foreground="White" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Source}" Foreground="#9CA3AF" FontSize="10"/>
                                            <ItemsControl ItemsSource="{Binding Lines}" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="#E5E7EB" FontSize="12" Margin="0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="Préparer" Style="{StaticResource Btn.Primary}" Margin="0,10,0,0"
                                                    Command="{Binding DataContext.AdvanceTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            <!-- Preparing -->
            <Border Background="#252836" CornerRadius="14" Margin="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding PreparingCount, StringFormat=En cours ({0})}" FontWeight="Bold" Foreground="#FB923C" Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PreparingTickets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3D2F1F" CornerRadius="12" Padding="12" Margin="0,0,0,8" BorderBrush="#FB923C" BorderThickness="2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="#FB923C" FontSize="16"/>
                                            <TextBlock Text="{Binding TabName}" Foreground="White" Margin="0,4,0,0"/>
                                            <ItemsControl ItemsSource="{Binding Lines}" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="#E5E7EB" FontSize="12" Margin="0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="Prêt" Style="{StaticResource Btn.Primary}" Margin="0,10,0,0"
                                                    Command="{Binding DataContext.AdvanceTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            <!-- Ready -->
            <Border Background="#252836" CornerRadius="14" Margin="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding ReadyCount, StringFormat=Prêt ({0})}" FontWeight="Bold" Foreground="#4ADE80" Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ReadyTickets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1F3D2A" CornerRadius="12" Padding="12" Margin="0,0,0,8" BorderBrush="#4ADE80" BorderThickness="2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="#4ADE80" FontSize="16"/>
                                            <TextBlock Text="{Binding TabName}" Foreground="White" Margin="0,4,0,0"/>
                                            <Button Content="Servi" Margin="0,10,0,0" Padding="12,8"
                                                    Command="{Binding DataContext.BumpTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
