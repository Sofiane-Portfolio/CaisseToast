<UserControl x:Class="CaisseToast.Wpf.Views.ShellHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="66">
    <Border Background="{StaticResource Brush.HeaderGradient}" Padding="24,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                <Border Width="36" Height="42" CornerRadius="8" Background="#1AFFFFFF" Margin="0,0,12,0">
                    <TextBlock Text="LB" Foreground="White" FontWeight="Bold" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="LIGHT BANANA" Foreground="{StaticResource Brush.Sky}" FontSize="9" FontWeight="Bold"/>
                    <TextBlock Text="{Binding RestaurantName}" Foreground="White" FontSize="17" FontWeight="Bold"/>
                    <TextBlock Foreground="#8FFFFFFF" FontSize="10">
                        <Run Text="{Binding RegisterName, Mode=OneWay}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding UserRole, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <Rectangle Grid.Column="1" Width="1" Fill="#24FFFFFF" Margin="0,14"/>

            <!-- Info pills -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Style="{StaticResource HeaderPill}">
                    <StackPanel>
                        <TextBlock Text="DATE &amp; HEURE" Foreground="#73FFFFFF" FontSize="8" FontWeight="Bold"/>
                        <TextBlock Foreground="White" FontSize="12" FontWeight="Bold">
                            <Run Text="{Binding DateText, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding TimeText, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HeaderPill}">
                    <StackPanel>
                        <TextBlock Text="CODE EMPLOYÉ" Foreground="#73FFFFFF" FontSize="8" FontWeight="Bold"/>
                        <TextBlock Text="{Binding EmployeeCode}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HeaderPill}">
                    <StackPanel>
                        <TextBlock Text="TICKET" Foreground="#73FFFFFF" FontSize="8" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TicketNumber}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HeaderPill}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource Brush.Live}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="CAISSE" Foreground="#73FFFFFF" FontSize="8" FontWeight="Bold"/>
                            <TextBlock Text="{Binding RegisterName}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Actions -->
            <Border Grid.Column="3" Background="#26000000" BorderBrush="#1AFFFFFF" BorderThickness="1"
                    CornerRadius="14" Padding="5">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Accueil" Style="{StaticResource Btn.HeaderGhost}" Margin="2,0"
                            Command="{Binding GoHomeCommand}"/>
                    <Button Content="Admin" Style="{StaticResource Btn.HeaderGhost}" Margin="2,0"
                            Command="{Binding OpenAdminCommand}"/>
                    <Button Content="Déconnexion" Margin="2,0" Cursor="Hand"
                            Command="{Binding LogoutCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#73B41E32" CornerRadius="10" Padding="14,8">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#99C82832"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#FECACA"/>
                        </Button.Foreground>
                        <Button.FontWeight>Bold</Button.FontWeight>
                        <Button.FontSize>11</Button.FontSize>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
