<Application x:Class="CaisseToast.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CaisseToast.Wpf.ViewModels"
             xmlns:v="clr-namespace:CaisseToast.Wpf.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/LightBananaTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ViewModel → View -->
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <v:LoginView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <v:HomeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
                <v:PlaceholderView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
